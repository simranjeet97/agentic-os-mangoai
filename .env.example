# Agentic OS - Environment Configuration Template
# Copy this file to .env and fill in your actual keys

ENVIRONMENT=development
LOG_LEVEL=INFO

# LLM Configuration
OLLAMA_BASE_URL=http://localhost:11434
PRIMARY_MODEL=llama3.2:3b
LLM_PROVIDER=gemini
GEMINI_DEFAULT_MODEL=gemini-3-flash-preview

# Google Gemini API Key (Required for gemini provider)
# Get one at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Persistence (Missing services will trigger stubs)
REDIS_HOST=localhost
REDIS_PORT=6379
CHROMA_DB_PATH=./chroma_data

# Sandbox
SANDBOX_DOCKER_IMAGE=agentic-os-sandbox:latest

# Security
# Generate a secret key for production using: openssl rand -hex 32
SECRET_KEY=your_secret_key_here
AUTH_TOKEN_EXPIRE_MINUTES=1440

# Tavily API Key (Optional, for web search agent)
# Get one at https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here
