# =============================================================================
# Agentic AI OS — .gitignore
# =============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
venv
env/
test_env/
lib/
.python-version

# Environment & Secrets
.env
.env.*
!.env.example
*.pem
*.key
*.cert
secrets/

# Database & Persistent Data (Local Only)
*.db
*.sqlite
chroma_data/
redis_data/
debug_episodic.db

# Logs & Temporary Files
logs/
*.log
*.log.*
pip_output.txt
scratch/
sandbox_tmp/

# Project Specific Artifacts
artifacts/
.gemini/

# Node.js / UI
node_modules/
ui/node_modules/
ui/dist/
ui/dist-electron/
.pnpm-store/

# Docker
.docker/

# IDE & OS
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Testing & Linting
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

